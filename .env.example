# Salin ke .env.local lalu isi nilainya.

# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@ep-xxx.neon.tech/manajemen_surat?sslmode=require"

# Auth (Better Auth)
BETTER_AUTH_SECRET="generate-dengan: openssl rand -base64 32"
BETTER_AUTH_URL="http://localhost:6700"

# Storage Provider
# local | cloudinary | hosted
STORAGE_PROVIDER="local"
STORAGE_ENV_PREFIX="dev"
# WAJIB di luar folder ./public agar tidak bisa diakses tanpa autentikasi.
# File akan di-serve via Route Handler /api/files yang memerlukan login.
STORAGE_LOCAL_DIR="./storage/uploads"
STORAGE_PUBLIC_BASE_URL="/api/files"
STORAGE_MAX_FILE_MB="10"
STORAGE_ALLOWED_MIME_TYPES="application/pdf,image/jpeg,image/png,image/webp,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document"

# File Upload (Cloudinary)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Email (Mailjet)
MAILJET_API_KEY=""
MAILJET_API_SECRET=""
MAILJET_FROM_EMAIL="noreply@iai-jakarta.or.id"
MAILJET_FROM_NAME="ARKA IAI Jakarta"

# App
NEXT_PUBLIC_APP_NAME="ARKA"
NEXT_PUBLIC_APP_URL="http://localhost:6700"
